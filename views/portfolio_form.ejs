<div class="form-wrapper">
  <div class="form-card">

    <h1>포트폴리오 <%= action === 'edit' ? '수정' : '등록' %></h1>

    <form action="<%= action === 'edit' ? '/portfolio/' + item.item_id + '/edit' : '/portfolio/new' %>" method="post">

      <div class="form-row">
        <label>제목</label>
        <input type="text" name="title" value="<%= item ? item.title : '' %>" required>
      </div>

      <div class="form-row">
        <label>요약</label>
        <input type="text" name="summary" value="<%= item ? item.summary : '' %>">
      </div>

      <div class="form-row">
        <label>카테고리</label>
        <input type="text" name="category" value="<%= item ? item.category : 'PROJECT' %>">
      </div>

      <div class="form-row">
        <label>Github URL</label>
        <input type="url" name="github_url" value="<%= item ? item.github_url : '' %>">
      </div>

      <div class="form-row">
        <label>Demo URL</label>
        <input type="url" name="demo_url" value="<%= item ? item.demo_url : '' %>">
      </div>

      <div class="form-row">
        <label>내용</label>
        <textarea name="content" rows="10" required><%= item ? item.content : '' %></textarea>
      </div>

      <div class="form-row checkbox-label">
        <input type="checkbox" name="is_public" value="1"
          <%= item ? (item.is_public ? "checked" : "") : "checked" %>>
        <label>공개 여부</label>
      </div>

      <button type="submit" class="btn btn-primary"><%= action === 'edit' ? '수정' : '등록' %></button>

    </form>

    <p class="mt-3">
      <a href="/portfolio">목록으로</a>
    </p>

  </div>
</div>
